<Window x:Class="SplitWallpaper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Split Wallpaper"
        Width="1420"
        Height="1080"
        MinWidth="1100"
        MinHeight="760"
        Loaded="Window_OnLoaded"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="34"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       Text="Split Wallpaper" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="{StaticResource MutedTextBrush}"
                       Text="单屏左右分割、拖拽预览、输出主显示器真实分辨率壁纸。" />
        </StackPanel>

        <Border x:Name="SettingsCard"
                Grid.Row="1"
                Margin="0,20,0,14"
                Padding="18,16"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,24,0">
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               Text="图片设置" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="设置左右壁纸、填充模式与分割比例。" />
                </StackPanel>

                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Width="172"
                            Height="40"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="ApplyWallpaper_Click"
                            Content="应用壁纸"
                            IsEnabled="{Binding CanApply}" />
                </StackPanel>

                <Grid Grid.Row="1"
                      Grid.ColumnSpan="2"
                      Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Foreground="{StaticResource PrimaryTextBrush}" Text="左侧图片" />
                        <DockPanel Margin="0,8,0,0" LastChildFill="True">
                            <Button Width="116"
                                    Margin="12,0,0,0"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="SelectLeftImage_Click"
                                    Content="选择左图" />
                            <TextBox IsReadOnly="True"
                                     Style="{StaticResource WindowTextBoxStyle}"
                                     Text="{Binding LeftImagePath, Mode=OneWay, TargetNullValue=尚未选择}" />
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Foreground="{StaticResource PrimaryTextBrush}" Text="右侧图片" />
                        <DockPanel Margin="0,8,0,0" LastChildFill="True">
                            <Button Width="116"
                                    Margin="12,0,0,0"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="SelectRightImage_Click"
                                    Content="选择右图" />
                            <TextBox IsReadOnly="True"
                                     Style="{StaticResource WindowTextBoxStyle}"
                                     Text="{Binding RightImagePath, Mode=OneWay, TargetNullValue=尚未选择}" />
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,16,0,0">
                        <TextBlock Foreground="{StaticResource PrimaryTextBrush}" Text="填充模式" />
                        <ComboBox Margin="0,8,0,0"
                                  Style="{StaticResource WindowComboBoxStyle}"
                                  ItemsSource="{Binding FillModes}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding SelectedFillMode, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="2"
                                Margin="0,16,0,0">
                        <TextBlock Foreground="{StaticResource PrimaryTextBrush}" Text="分割比例" />
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="64" />
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0"
                                    Minimum="10"
                                    Maximum="90"
                                    SmallChange="1"
                                    LargeChange="1"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Style="{StaticResource WindowSliderStyle}"
                                    Value="{Binding SplitSliderValue, Mode=TwoWay}" />
                            <TextBlock Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontWeight="SemiBold"
                                       Text="{Binding SplitRatioText}" />
                        </Grid>
                    </StackPanel>

                    <TextBlock Grid.Row="2"
                               Grid.ColumnSpan="3"
                               Margin="0,14,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Text="预览区域会按主显示器真实比例缩放显示。你的主显示器越宽，预览就越接近真实的超宽屏观感。" />
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="PreviewCard"
                Grid.Row="2"
                Margin="0,0,0,14"
                Padding="18,16"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Margin="0,0,18,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="{Binding PrimaryDisplaySummaryText}" />
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding SplitRatioText}" />
                    </StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               Text="实时预览" />
                </DockPanel>

                <Border Grid.Row="1"
                        Margin="0,16,0,0"
                        Background="#08111F"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid x:Name="PreviewViewport"
                          Margin="10"
                          SizeChanged="PreviewViewport_OnSizeChanged">
                        <Grid x:Name="PreviewHost"
                              Width="{Binding PreviewSurfaceWidth}"
                              Height="{Binding PreviewSurfaceHeight}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              SizeChanged="PreviewHost_OnSizeChanged">
                            <Border Background="#020617"
                                    BorderBrush="#213047"
                                    BorderThickness="1"
                                    CornerRadius="12" />
                            <Image Source="{Binding PreviewImageSource}"
                                   Stretch="Fill" />
                            <Canvas x:Name="PreviewOverlay"
                                    Background="Transparent">
                                <Border x:Name="SplitLine"
                                        Width="2"
                                        Background="#E2E8F0"
                                        IsHitTestVisible="False" />
                                <primitives:Thumb x:Name="SplitThumb"
                                                  Width="24"
                                                  Cursor="SizeWE"
                                                  DragDelta="SplitThumb_OnDragDelta">
                                    <primitives:Thumb.Template>
                                        <ControlTemplate TargetType="primitives:Thumb">
                                            <Grid>
                                                <Border Background="#00FFFFFF" />
                                                <Border Width="8"
                                                        Height="72"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Background="#F8FAFC"
                                                        CornerRadius="4" />
                                            </Grid>
                                        </ControlTemplate>
                                    </primitives:Thumb.Template>
                                </primitives:Thumb>
                            </Canvas>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="StatusCard"
                Grid.Row="3"
                Padding="16,14"
                Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           Text="状态" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
